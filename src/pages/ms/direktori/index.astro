---
import Base from '../../../layouts/Base.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ProviderCard from '../../../components/ProviderCard.astro';
import clinicsData from '../../../data/providers.json';
import categoriesData from '../../../data/categories.json';
import statesData from '../../../data/states.json';

const path = '/ms/direktori';
const altLocaleHref = '/providers';

const totalCount = clinicsData.length;

// Count providers per category
const categoryCounts: Record<string, number> = {};
for (const cat of categoriesData) {
  categoryCounts[cat.slug] = clinicsData.filter(c => (c.categories || []).includes(cat.slug)).length;
}

// Count providers per state
const stateCounts: Record<string, number> = {};
for (const clinic of clinicsData) {
  if (clinic.state) {
    stateCounts[clinic.state] = (stateCounts[clinic.state] || 0) + 1;
  }
}

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Direktori Keselamatan Siber Malaysia',
  description: `Semak imbas ${totalCount} pembekal keselamatan siber yang disahkan di seluruh Malaysia. Keselamatan terurus, ujian penembusan, keselamatan awan, pematuhan GRC, SOC dan lain-lain.`,
  url: 'https://cybersecuresme.my/ms/direktori',
  inLanguage: 'ms-MY',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Laman Utama', item: 'https://cybersecuresme.my/ms' },
      { '@type': 'ListItem', position: 2, name: 'Direktori', item: 'https://cybersecuresme.my/ms/direktori' },
    ],
  },
};
---

<Base
  title="Direktori Pembekal Keselamatan Siber Malaysia | Cyber Secure SME"
  description={`Semak imbas ${totalCount} pembekal keselamatan siber yang disahkan di seluruh Malaysia. Keselamatan terurus, ujian penembusan, keselamatan awan, pematuhan GRC, SOC dan lain-lain.`}
  locale="ms"
  altLocaleHref={altLocaleHref}
  canonical="https://cybersecuresme.my/ms/direktori"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <SiteHeader locale="ms" currentPath={path} altLocaleHref={altLocaleHref} />

  <main id="main-content">

    <!-- Hero header -->
    <section style="background:#f2f2f2;border-bottom:1px solid #181818;padding:64px 0 52px;">
      <div class="container">
        <p class="eyebrow" style="margin:0 0 14px 0;">DIREKTORI YANG DISAHKAN</p>
        <h1 class="heading" style="font-size:clamp(28px,4vw,44px);margin:0 0 18px 0;line-height:1.05;">
          Pembekal Keselamatan Siber di Malaysia
        </h1>
        <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:18px;color:#181818;line-height:1.55;max-width:600px;margin:0 0 10px 0;">
          Cari pembekal yang disahkan merentasi 8 kategori perkhidmatan dan 16 negeri. Setiap penyenaraian dirujuk silang dengan rekod NACSA, CyberSecurity Malaysia, dan SSM.
        </p>
        <p class="eyebrow" style="margin:0;color:#6e6e6e;">
          {totalCount} PEMBEKAL &nbsp;&#183;&nbsp; 8 KATEGORI &nbsp;&#183;&nbsp; 16 NEGERI
        </p>
      </div>
    </section>

    <!-- Category filter chips -->
    <section style="padding:36px 0 0;" aria-label="Tapis mengikut kategori">
      <div class="container">
        <p class="eyebrow" style="margin:0 0 14px 0;color:#6e6e6e;">SEMAK IMBAS MENGIKUT KATEGORI</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {categoriesData.map(cat => (
            <a
              href={`/ms/direktori/${cat.slug}`}
              style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:0.05em;color:#181818;background:#f2f2f2;border:1px solid #181818;padding:7px 16px;text-decoration:none;transition:background 120ms ease,color 120ms ease;min-height:36px;display:inline-flex;align-items:center;gap:8px;border-radius:0;"
              class="filter-chip"
            >
              {cat.name_ms}
              <span style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:0.02em;color:#6e6e6e;">
                {categoryCounts[cat.slug] || 0}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- State filter chips -->
    <section style="padding:20px 0 36px;" aria-label="Tapis mengikut negeri">
      <div class="container">
        <p class="eyebrow" style="margin:0 0 14px 0;color:#6e6e6e;">SEMAK IMBAS MENGIKUT NEGERI</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {statesData.filter(s => stateCounts[s.slug] > 0).map(state => (
            <a
              href={`/ms/direktori?state=${state.slug}`}
              style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:0.05em;color:#181818;background:#f2f2f2;border:1px solid #181818;padding:7px 16px;text-decoration:none;transition:background 120ms ease,color 120ms ease;min-height:36px;display:inline-flex;align-items:center;gap:8px;border-radius:0;"
              class="filter-chip"
            >
              {state.name_ms}
              <span style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;letter-spacing:0.02em;color:#6e6e6e;">
                {stateCounts[state.slug]}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Provider grid -->
    <section style="padding:0 0 96px;" aria-label="Semua pembekal">
      <div class="container">
        <div class="clinic-grid">
          {clinicsData.map(clinic => (
            <ProviderCard clinic={clinic} locale="ms" />
          ))}
        </div>

        <!-- CTA: list your company -->
        <div style="margin-top:64px;border:1px solid #181818;padding:44px 36px;text-align:center;background:#f2f2f2;">
          <p class="eyebrow" style="margin:0 0 14px 0;color:#6e6e6e;">UNTUK FIRMA KESELAMATAN SIBER</p>
          <h2 class="heading" style="font-size:26px;margin:0 0 14px 0;">Adakah syarikat anda tersenarai?</h2>
          <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#6e6e6e;line-height:1.6;margin:0 0 28px 0;max-width:480px;margin-left:auto;margin-right:auto;">
            Tuntut penyenaraian percuma anda atau naik taraf ke profil yang disahkan untuk menjangkau perniagaan yang mencari perkhidmatan anda.
          </p>
          <a
            href="/ms/senaraikan-syarikat"
            class="btn-primary"
            data-ph="cta_list_company_ms_directory"
          >
            Senaraikan syarikat anda
            <span aria-hidden="true" style="color:#fc523b;">&#8599;</span>
          </a>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter locale="ms" currentPath={path} altLocaleHref={altLocaleHref} />

</Base>

<style>
  .clinic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) {
    .clinic-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .clinic-grid { grid-template-columns: 1fr; }
  }
  .filter-chip:hover { background: #181818; color: #f2f2f2; }
  @media (prefers-reduced-motion: reduce) {
    .filter-chip { transition: none; }
  }
</style>
