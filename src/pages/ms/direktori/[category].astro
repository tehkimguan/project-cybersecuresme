---
import Base from '../../../layouts/Base.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ProviderCard from '../../../components/ProviderCard.astro';
import clinicsData from '../../../data/providers.json';
import categoriesData from '../../../data/categories.json';

export async function getStaticPaths() {
  return categoriesData.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const path = `/ms/direktori/${category.slug}`;
const altLocaleHref = `/providers/${category.slug}`;

const clinics = clinicsData.filter(c => (c.categories || []).includes(category.slug));

// Tool links relevant by category (MS slugs from tools.ts)
const toolLinks: Record<string, { label: string; slug: string }[]> = {
  'managed-security': [
    { label: 'Penganggar Bajet Keselamatan', slug: 'penganggar-bajet-keselamatan' },
    { label: 'Penilaian Kematangan Siber', slug: 'penilaian-kematangan-siber' },
    { label: 'Kalkulator Kos Gangguan IT', slug: 'kalkulator-kos-gangguan' },
  ],
  'endpoint-network': [
    { label: 'Skor Pendedahan Ransomware', slug: 'skor-pendedahan-ransomware' },
    { label: 'Penyemak Kekuatan Kata Laluan', slug: 'penyemak-kekuatan-kata-laluan' },
    { label: 'Penilaian Kematangan Siber', slug: 'penilaian-kematangan-siber' },
  ],
  'penetration-testing': [
    { label: 'Penilaian Kematangan Siber', slug: 'penilaian-kematangan-siber' },
    { label: 'Skor Pendedahan Ransomware', slug: 'skor-pendedahan-ransomware' },
    { label: 'Penganggar Kos Pelanggaran Data', slug: 'penganggar-kos-pelanggaran-data' },
  ],
  'cloud-security': [
    { label: 'Semakan Risiko Pancingan', slug: 'semakan-risiko-pancingan' },
    { label: 'Penganggar Bajet Keselamatan', slug: 'penganggar-bajet-keselamatan' },
    { label: 'Penyemak Kesediaan PDPA', slug: 'penyemak-kesediaan-pdpa' },
  ],
  'grc-compliance': [
    { label: 'Penyemak Kesediaan PDPA', slug: 'penyemak-kesediaan-pdpa' },
    { label: 'Penilaian Kematangan Siber', slug: 'penilaian-kematangan-siber' },
    { label: 'Penganggar Bajet Keselamatan', slug: 'penganggar-bajet-keselamatan' },
  ],
  'soc-incident': [
    { label: 'Kalkulator Kos Gangguan IT', slug: 'kalkulator-kos-gangguan' },
    { label: 'Penganggar Kos Pelanggaran Data', slug: 'penganggar-kos-pelanggaran-data' },
    { label: 'Skor Pendedahan Ransomware', slug: 'skor-pendedahan-ransomware' },
  ],
  'security-awareness': [
    { label: 'Semakan Risiko Pancingan', slug: 'semakan-risiko-pancingan' },
    { label: 'Penyemak Kekuatan Kata Laluan', slug: 'penyemak-kekuatan-kata-laluan' },
    { label: 'Penyemak Kesediaan PDPA', slug: 'penyemak-kesediaan-pdpa' },
  ],
  'data-backup': [
    { label: 'Skor Pendedahan Ransomware', slug: 'skor-pendedahan-ransomware' },
    { label: 'Kalkulator Kos Gangguan IT', slug: 'kalkulator-kos-gangguan' },
    { label: 'Penganggar Kos Pelanggaran Data', slug: 'penganggar-kos-pelanggaran-data' },
  ],
};

const tools = toolLinks[category.slug] || [
  { label: 'Penilaian Kematangan Siber', slug: 'penilaian-kematangan-siber' },
  { label: 'Penganggar Bajet Keselamatan', slug: 'penganggar-bajet-keselamatan' },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${category.name_ms} di Malaysia`,
  description: `${category.description_ms} Semak imbas ${clinics.length} pembekal yang disahkan.`,
  url: `https://cybersecuresme.my/ms/direktori/${category.slug}`,
  inLanguage: 'ms-MY',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Laman Utama', item: 'https://cybersecuresme.my/ms' },
      { '@type': 'ListItem', position: 2, name: 'Direktori', item: 'https://cybersecuresme.my/ms/direktori' },
      { '@type': 'ListItem', position: 3, name: category.name_ms, item: `https://cybersecuresme.my/ms/direktori/${category.slug}` },
    ],
  },
};
---

<Base
  title={`${category.name_ms} di Malaysia | Cyber Secure SME`}
  description={`${category.description_ms} Semak imbas ${clinics.length} pembekal ${category.name_ms.toLowerCase()} yang disahkan di seluruh Malaysia.`}
  locale="ms"
  altLocaleHref={altLocaleHref}
  canonical={`https://cybersecuresme.my/ms/direktori/${category.slug}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <SiteHeader locale="ms" currentPath={path} altLocaleHref={altLocaleHref} />

  <main id="main-content">

    <!-- Category hero -->
    <section style="background:#f2f2f2;border-bottom:1px solid #181818;padding:64px 0 52px;">
      <div class="container">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" style="margin-bottom:24px;">
          <ol style="display:flex;align-items:center;gap:8px;list-style:none;margin:0;padding:0;font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:11px;letter-spacing:0.05em;color:#6e6e6e;flex-wrap:wrap;">
            <li><a href="/ms" style="color:#6e6e6e;text-decoration:none;">Utama</a></li>
            <li aria-hidden="true" style="color:#d6d6cf;">/</li>
            <li><a href="/ms/direktori" style="color:#6e6e6e;text-decoration:none;">Direktori</a></li>
            <li aria-hidden="true" style="color:#d6d6cf;">/</li>
            <li aria-current="page" style="color:#181818;">{category.name_ms}</li>
          </ol>
        </nav>

        <p class="eyebrow" style="margin:0 0 14px 0;">{category.name_ms.toUpperCase()}</p>
        <h1 class="heading" style="font-size:clamp(26px,3.5vw,40px);margin:0 0 18px 0;line-height:1.05;">
          {category.name_ms} di Malaysia
        </h1>
        <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:18px;color:#181818;line-height:1.55;max-width:640px;margin:0 0 18px 0;">
          {category.description_ms}
        </p>
        <p class="eyebrow" style="margin:0;color:#6e6e6e;">
          {clinics.length === 0 ? 'TIADA PEMBEKAL TERSENARAI LAGI' : `${clinics.length} PEMBEKAL${clinics.length === 1 ? '' : ''} TERSENARAI`}
        </p>

        <!-- Subcategory chips -->
        {category.subcategories && category.subcategories.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:22px;" role="list" aria-label="Subkategori">
            {category.subcategories.map(sub => (
              <span
                role="listitem"
                style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:11px;letter-spacing:0.05em;color:#6e6e6e;background:transparent;border:1px solid #d6d6cf;padding:4px 10px;"
              >
                {sub}
              </span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Provider grid or empty state -->
    <section style="padding:52px 0 68px;" aria-label={`Pembekal ${category.name_ms}`}>
      <div class="container">
        {clinics.length === 0 ? (
          <div style="border:1px solid #181818;padding:64px 32px;text-align:center;background:#ffffff;">
            <p class="eyebrow" style="margin:0 0 16px 0;color:#6e6e6e;">AKAN DATANG</p>
            <h2 class="heading" style="font-size:24px;margin:0 0 14px 0;">Mengesahkan pembekal dalam kategori ini</h2>
            <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#6e6e6e;line-height:1.6;max-width:440px;margin:0 auto 28px auto;">
              Kami sedang mengesahkan pembekal {category.name_ms.toLowerCase()} untuk direktori ini. Senaraikan syarikat anda untuk menjadi antara yang pertama.
            </p>
            <a href="/ms/senaraikan-syarikat" class="btn-primary">
              Senaraikan syarikat anda
              <span aria-hidden="true" style="color:#fc523b;">&#8599;</span>
            </a>
          </div>
        ) : (
          <div class="clinic-grid">
            {clinics.map(clinic => (
              <ProviderCard clinic={clinic} locale="ms" />
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Related security tools -->
    <section style="border-top:1px solid #d6d6cf;padding:48px 0;" aria-label="Alat keselamatan berkaitan">
      <div class="container">
        <p class="eyebrow" style="margin:0 0 18px 0;color:#6e6e6e;">ALAT KESELAMATAN BERKAITAN</p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          {tools.map(tool => (
            <a
              href={`/ms/alat/${tool.slug}`}
              style="display:inline-flex;align-items:center;gap:6px;min-height:40px;padding:0 18px;background:#f2f2f2;border:1px solid #181818;font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;text-decoration:none;transition:background 120ms ease,color 120ms ease;border-radius:0;"
              class="tool-link"
            >
              {tool.label}
              <span aria-hidden="true" style="color:#fc523b;font-size:14px;">&#8599;</span>
            </a>
          ))}
          <a
            href="/ms/alat"
            style="display:inline-flex;align-items:center;min-height:40px;padding:0 18px;background:transparent;border:1px solid #d6d6cf;font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:0.05em;text-transform:uppercase;color:#6e6e6e;text-decoration:none;"
          >
            Semua alat
          </a>
        </div>
      </div>
    </section>

    <!-- Related reading -->
    <section style="border-top:1px solid #d6d6cf;padding:36px 0 52px;" aria-label="Artikel berkaitan">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <div>
          <p class="eyebrow" style="margin:0 0 8px 0;color:#6e6e6e;">BACAAN BERKAITAN</p>
          <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;margin:0;">
            Baca panduan dan artikel kami mengenai {category.name_ms.toLowerCase()}.
          </p>
        </div>
        <a href="/ms/blog" class="btn-secondary">
          Baca blog
        </a>
      </div>
    </section>

    <!-- Disclaimer -->
    <section style="padding:0 0 64px;">
      <div class="container">
        <div style="border:1px solid #d6d6cf;padding:18px 22px;background:#f2f2f2;">
          <p class="eyebrow" style="margin:0 0 6px 0;color:#6e6e6e;font-size:10px;">NOTIS DIREKTORI</p>
          <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:15px;color:#6e6e6e;line-height:1.65;margin:0;">
            Cyber Secure SME ialah direktori bebas dan tidak menyediakan nasihat keselamatan. Sentiasa sahkan lesen NACSA, pensijilan, dan kelayakan pembekal secara langsung sebelum melibatkan mereka.
          </p>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter locale="ms" currentPath={path} altLocaleHref={altLocaleHref} />

</Base>

<style>
  .clinic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) {
    .clinic-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .clinic-grid { grid-template-columns: 1fr; }
  }
  .tool-link:hover { background: #181818; color: #f2f2f2; }
  @media (prefers-reduced-motion: reduce) {
    .tool-link { transition: none; }
  }
</style>
