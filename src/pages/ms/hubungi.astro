---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ProviderLeadForm from '../../components/ProviderLeadForm.astro';
---

<Base
  title="Hubungi Cyber Secure SME"
  description="Hubungi Cyber Secure SME untuk pertanyaan umum, pembetulan penyenaraian, atau untuk menuntut profil pembekal. E-mel cybersecuresme@agentmail.to atau gunakan borang."
  locale="ms"
  altLocaleHref="/contact"
  schemaType="breadcrumb"
  schemaData={{ items: [{ name: 'Utama', url: '/ms' }, { name: 'Hubungi', url: '/ms/hubungi' }] }}
>
  <SiteHeader locale="ms" currentPath="/ms/hubungi" altLocaleHref="/contact" />

  <main>
    <section style="background:#f2f2f2;border-bottom:1px solid #181818;padding:64px 0 52px;">
      <div class="container" style="max-width:800px;">
        <p class="eyebrow" style="margin:0 0 20px 0;">HUBUNGI</p>
        <h1 class="heading" style="font-size:clamp(26px,5vw,40px);margin:0 0 18px 0;line-height:1.05;">
          Berhubung dengan kami
        </h1>
        <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:18px;color:#181818;line-height:1.55;margin:0;">
          Untuk pertanyaan umum, pembetulan penyenaraian, laporan data tidak tepat, atau untuk menuntut profil pembekal, gunakan borang di bawah atau e-mel kami terus.
        </p>
      </div>
    </section>

    <section style="padding:64px 0;">
      <div class="container contact-grid">
        <!-- Form -->
        <div style="min-width:0;">
          <h2 class="heading" style="font-size:22px;margin:0 0 26px 0;">Hantar mesej kepada kami</h2>
          <ProviderLeadForm locale="ms" mode="general" />
        </div>

        <!-- Side info -->
        <aside style="min-width:0;">
          <div style="background:#ffffff;border:1px solid #181818;padding:28px;margin-bottom:20px;">
            <p class="eyebrow" style="margin:0 0 18px 0;">HUBUNGI TERUS</p>
            <div style="display:flex;flex-direction:column;gap:18px;">
              <div>
                <p class="eyebrow" style="margin:0 0 5px 0;color:#6e6e6e;">E-mel</p>
                <a href="mailto:cybersecuresme@agentmail.to" style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:18px;color:#181818;text-decoration:none;" class="arrow-link">cybersecuresme@agentmail.to</a>
              </div>
              <div>
                <p class="eyebrow" style="margin:0 0 5px 0;color:#6e6e6e;">WhatsApp</p>
                <a href="https://wa.me/601156210500" target="_blank" rel="noopener noreferrer" style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:18px;color:#181818;text-decoration:none;" class="arrow-link">+60 11-5621 0500</a>
              </div>
              <div>
                <p class="eyebrow" style="margin:0 0 5px 0;color:#6e6e6e;">Lokasi</p>
                <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;margin:0;">Malaysia</p>
              </div>
            </div>
          </div>

          <div style="background:#ffffff;border:1px solid #181818;padding:28px;margin-bottom:20px;">
            <p class="eyebrow" style="margin:0 0 18px 0;">MASA TINDAK BALAS</p>
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px;">
              <li style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;display:flex;gap:12px;align-items:flex-start;">
                <span aria-hidden="true" style="color:#fc523b;flex-shrink:0;margin-top:4px;font-size:10px;">&#9632;</span>
                <span>Pertanyaan umum: dalam masa 2 hari bekerja</span>
              </li>
              <li style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;display:flex;gap:12px;align-items:flex-start;">
                <span aria-hidden="true" style="color:#fc523b;flex-shrink:0;margin-top:4px;font-size:10px;">&#9632;</span>
                <span>Ketidaktepatan penyenaraian: disemak dalam masa 5 hari bekerja</span>
              </li>
              <li style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;display:flex;gap:12px;align-items:flex-start;">
                <span aria-hidden="true" style="color:#fc523b;flex-shrink:0;margin-top:4px;font-size:10px;">&#9632;</span>
                <span>Permohonan penyenaraian: disemak dalam masa 3 hari bekerja</span>
              </li>
            </ul>
          </div>

          <div style="background:#f2f2f2;border:1px solid #181818;padding:28px;">
            <p class="eyebrow" style="margin:0 0 14px 0;">FIRMA KESELAMATAN SIBER</p>
            <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#181818;line-height:1.55;margin:0 0 18px 0;">
              Ingin menyenaraikan atau menuntut profil syarikat anda?
            </p>
            <a href="/ms/senaraikan-syarikat" class="btn-primary" style="font-size:16px;">
              Senaraikan syarikat anda
              <span aria-hidden="true" style="color:#fc523b;">&#8599;</span>
            </a>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter locale="ms" currentPath="/ms/hubungi" altLocaleHref="/contact" />

  <style>
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 48px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .contact-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Utama", "item": "https://cybersecuresme.my/ms" },
        { "@type": "ListItem", "position": 2, "name": "Hubungi", "item": "https://cybersecuresme.my/ms/hubungi" }
      ]
    })}
  </script>
</Base>
