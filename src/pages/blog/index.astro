---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 12;
const url = Astro.url;
const pageParam = url.searchParams.get('page');
const currentPage = pageParam ? Math.max(1, parseInt(pageParam, 10)) : 1;

const allPosts = (await getCollection('blog', ({ data }) => {
  return data.locale === 'en' && !data.draft;
})).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-MY', { day: 'numeric', month: 'short', year: 'numeric' });
}

function getSlug(entry: (typeof allPosts)[0]): string {
  return entry.slug;
}
---

<Base
  title="Cybersecurity Guides for Malaysian SMEs | Cyber Secure SME"
  description="Plain-language cybersecurity guides for Malaysian business owners: PDPA compliance, ransomware defence, phishing prevention, NACSA licensing, and choosing the right security provider."
  locale="en"
  altLocaleHref="/ms/blog"
>
  <SiteHeader locale="en" currentPath="/blog" altLocaleHref="/ms/blog" />

  <main>
    <!-- Page header -->
    <section style="padding:72px 0 48px 0;border-bottom:1px solid #181818;">
      <div class="container">
        <p class="eyebrow" style="margin:0 0 16px 0;">CYBERSECURITY GUIDES</p>
        <h1 class="heading" style="font-size:clamp(28px,5vw,48px);margin:0 0 18px 0;line-height:1.05;max-width:700px;">
          Security guides for Malaysian SMEs
        </h1>
        <p style="font-size:17px;line-height:1.65;color:#3a4047;margin:0;max-width:600px;">
          Plain-language articles to help Malaysian businesses understand their cyber risks,
          meet PDPA and NACSA obligations, and choose the right security providers.
        </p>
      </div>
    </section>

    <!-- Trust strip -->
    <div style="border-bottom:1px solid #d6d6cf;padding:14px 0;">
      <div class="container" style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;">
        <span class="eyebrow" style="flex-shrink:0;color:#6e6e6e;">REFERENCES</span>
        {['NACSA (Act 854)', 'CyberSecurity Malaysia', 'PDPA / JPDP (Act 709)', 'MCMC', 'BNM RMiT', 'ISO/IEC 27001'].map(reg => (
          <span class="eyebrow" style="color:#6e6e6e;display:flex;align-items:center;gap:5px;text-transform:none;letter-spacing:0.03em;font-size:11px;">
            <span style="width:5px;height:5px;border:1px solid #181818;flex-shrink:0;"></span>
            {reg}
          </span>
        ))}
      </div>
    </div>

    <!-- Article list -->
    <section>
      <div class="container" style="padding-top:0;padding-bottom:0;">
        {posts.length === 0 && (
          <p style="padding:64px 0;color:#6e6e6e;font-size:17px;">No articles published yet. Check back soon.</p>
        )}
        {posts.map((post, i) => (
          <article style={`padding:36px 0;border-bottom:1px solid #d6d6cf;${i === 0 ? 'padding-top:44px;' : ''}`}>
            <div style="display:flex;align-items:flex-start;gap:32px;flex-wrap:wrap;">
              <div style="flex:1;min-width:260px;">

                <!-- Meta row -->
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
                  <time
                    datetime={post.data.publishedAt.toISOString()}
                    class="eyebrow"
                    style="color:#6e6e6e;"
                  >
                    {formatDate(post.data.publishedAt)}
                  </time>
                  {post.data.categories.length > 0 && (
                    <span class="eyebrow" style="color:#181818;background:#ececec;padding:2px 8px;">
                      {post.data.categories[0].replace(/-/g,' ')}
                    </span>
                  )}
                  {post.data.readingTime && (
                    <span class="eyebrow" style="color:#6e6e6e;">
                      {post.data.readingTime} MIN READ
                    </span>
                  )}
                </div>

                <!-- Title -->
                <h2 class="heading" style="font-size:clamp(20px,2.5vw,26px);margin:0 0 10px 0;line-height:1.2;">
                  <a
                    href={`/blog/${getSlug(post)}`}
                    class="post-title-link"
                  >
                    {post.data.title}
                  </a>
                </h2>

                <!-- Description -->
                <p style="font-size:16px;line-height:1.62;color:#3a4047;margin:0 0 16px 0;max-width:680px;">
                  {post.data.description}
                </p>

                <!-- Arrow link -->
                <a href={`/blog/${getSlug(post)}`} class="arrow-link" style="font-size:17px;">
                  Read article
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav style="padding:48px 0;" aria-label="Blog pagination">
        <div class="container" style="display:flex;justify-content:space-between;align-items:center;">
          {currentPage > 1 ? (
            <a
              href={`/blog${currentPage - 1 > 1 ? `?page=${currentPage - 1}` : ''}`}
              class="btn-secondary"
              style="font-size:16px;"
            >
              &larr; Newer articles
            </a>
          ) : <span />}
          <span class="eyebrow" style="color:#6e6e6e;">
            PAGE {currentPage} OF {totalPages}
          </span>
          {currentPage < totalPages ? (
            <a
              href={`/blog?page=${currentPage + 1}`}
              class="btn-secondary"
              style="font-size:16px;"
            >
              Older articles &rarr;
            </a>
          ) : <span />}
        </div>
      </nav>
    )}
  </main>

  <SiteFooter locale="en" currentPath="/blog" altLocaleHref="/ms/blog" />
</Base>

<style>
  .post-title-link {
    color: #181818;
    text-decoration: none;
    transition: color 100ms;
  }
  .post-title-link:hover {
    color: #181818;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
