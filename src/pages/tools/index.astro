---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { tools } from '../../data/tools';
---

<Base
  title="Free Cybersecurity Tools | Cyber Secure SME"
  description="Free cybersecurity calculators for Malaysian SMEs: password strength checker, data breach cost estimator, PDPA readiness checker, ransomware exposure score, security maturity assessment, and more."
  locale="en"
  altLocaleHref="/ms/alat"
>
  <SiteHeader locale="en" currentPath="/tools" altLocaleHref="/ms/alat" />

  <main>
    <div class="container section">

      <!-- Page header -->
      <header style="margin-bottom:56px;padding-bottom:32px;border-bottom:1px solid #181818;">
        <p class="eyebrow" style="margin:0 0 14px 0;">SECURITY TOOLS &middot; FREE</p>
        <h1 class="heading" style="font-size:clamp(32px,5vw,48px);margin:0 0 20px 0;">
          Cybersecurity Calculators for Malaysian SMEs
        </h1>
        <p style="font-size:18px;line-height:1.6;color:#3a4047;max-width:560px;margin:0;">
          Free tools to help your business size, assess, and reduce its cyber risk.
          Results update as you type. No sign-up required.
        </p>
      </header>

      <!-- Tool grid -->
      <div class="tools-grid">
        {tools.map((tool) => (
          <a
            href={`/tools/${tool.slug}`}
            class="tool-card card-hover"
          >
            <div class="tool-card-inner">
              <p class="eyebrow" style="margin:0 0 12px 0;color:#6e6e6e;">
                {tool.category.replace(/-/g, ' ')}
              </p>
              <h2 class="heading" style="font-size:20px;margin:0 0 10px 0;line-height:1.2;">
                {tool.name}
              </h2>
              <p style="font-size:15px;line-height:1.55;color:#3a4047;margin:0 0 16px 0;flex:1;">
                {tool.description}
              </p>
              <span class="arrow-link" style="font-size:16px;">Open tool</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Disclaimer -->
      <p class="eyebrow" style="color:#6e6e6e;margin-top:56px;max-width:720px;text-transform:none;letter-spacing:0.04em;font-size:11px;line-height:1.65;">
        All calculators provide indicative estimates only and are not a substitute for professional cybersecurity advice.
        Always verify a provider's NACSA licence, certifications, and track record before engaging.
        Cyber Secure SME is an independent directory and does not provide security advice.
      </p>
    </div>
  </main>

  <SiteFooter locale="en" currentPath="/tools" altLocaleHref="/ms/alat" />
</Base>

<style>
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .tool-card {
    display: flex;
    text-decoration: none;
    border: 1px solid #181818;
  }

  .tool-card-inner {
    padding: 28px;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (max-width: 900px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .tools-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-card { transition: none; }
  }
</style>
