---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base
  title="Page Not Found | Cyber Secure SME"
  description="The page you are looking for could not be found. Return to Cyber Secure SME's directory of Malaysian cybersecurity providers."
  locale="en"
  altLocaleHref="/ms"
>
  <SiteHeader locale="en" currentPath="/404" altLocaleHref="/ms" />

  <main>
    <section style="background:#f2f2f2;border-bottom:1px solid #d6d6cf;padding:96px 0 80px;min-height:60vh;display:flex;align-items:center;">
      <div class="container" style="max-width:640px;">
        <p class="eyebrow" style="margin:0 0 20px 0;color:#6e6e6e;">404</p>
        <h1 class="heading" style="font-size:clamp(28px,5vw,48px);margin:0 0 22px 0;line-height:1.05;">
          Page not found
        </h1>
        <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:19px;color:#6e6e6e;line-height:1.55;margin:0 0 36px 0;">
          The page you are looking for does not exist or has moved. Browse the directory to find a cybersecurity provider in Malaysia.
        </p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:center;">
          <a href="/" class="btn-primary">
            Back to home
            <span aria-hidden="true" style="color:#fc523b;">&#8599;</span>
          </a>
          <a href="/providers" class="btn-secondary">Browse providers</a>
        </div>

        <hr class="hairline" style="margin:48px 0 32px 0;" />

        <p class="eyebrow" style="margin:0 0 14px 0;color:#6e6e6e;">QUICK LINKS</p>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;">
          <li><a href="/providers" class="arrow-link" style="font-size:17px;">Browse all providers</a></li>
          <li><a href="/about" class="arrow-link" style="font-size:17px;">About this directory</a></li>
          <li><a href="/tools" class="arrow-link" style="font-size:17px;">Free security tools</a></li>
          <li><a href="/contact" class="arrow-link" style="font-size:17px;">Contact us</a></li>
          <li><a href="/list-your-company" class="arrow-link" style="font-size:17px;">List your company</a></li>
        </ul>
      </div>
    </section>
  </main>

  <SiteFooter locale="en" currentPath="/404" altLocaleHref="/ms" />
</Base>
