---
import VerificationBadge from './VerificationBadge.astro';
import categoriesData from '../data/categories.json';

interface Provider {
  slug: string;
  name: string;
  description?: string;
  categories?: string[];
  state?: string;
  city?: string;
  verification_level?: string;
  services?: string[];
  phone?: string;
  website?: string;
  site_status?: string;
  verified?: boolean;
}

interface Props {
  clinic: Provider;
  locale?: string;
}

const { clinic, locale = 'en' } = Astro.props;

const isMS = locale === 'ms';
const prefix = isMS ? '/ms' : '';
const profileBase = isMS ? '/pembekal/' : '/provider/';
const href = `${prefix}${profileBase}${clinic.slug}`;

// Safe defaults
const name = clinic.name || '';
const description = clinic.description || '';
const categories = clinic.categories || [];
const services = (clinic.services || []).slice(0, 4);
const state = clinic.state || '';
const city = clinic.city || '';
const level = (clinic.verification_level || 'listed') as 'premium' | 'nacsa-licensed' | 'ssm-checked' | 'claimed' | 'listed';

// Build categories name map
const catsMap: Record<string, { name: string; name_ms: string }> = Object.fromEntries(
  categoriesData.map(c => [c.slug, { name: c.name, name_ms: c.name_ms }])
);

const topCats = categories.slice(0, 3);

// Location display: "City, State" with title-cased state
const stateLabel = state
  ? state.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  : '';
const locationParts = [city, stateLabel].filter(Boolean);
const locationStr = locationParts.join(', ');

const isPremium = level === 'premium';

const viewLabel = isMS ? 'Lihat pembekal' : 'View provider';
const websiteLabel = isMS ? 'Laman web' : 'Website';
---

<article
  class="card-hover"
  style={`background:#f2f2f2;border:1px solid #181818;border-radius:0;padding:24px;display:flex;flex-direction:column;gap:14px;position:relative;`}
>
  <!-- Verification badge -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
    <VerificationBadge level={level} locale={locale} />
    {isPremium && (
      <span style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:#6e6e6e;">
        {isMS ? 'PILIHAN' : 'FEATURED'}
      </span>
    )}
  </div>

  <!-- Name (EB Garamond) -->
  <a
    href={href}
    style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:22px;font-weight:400;letter-spacing:0.005em;color:#181818;text-decoration:none;line-height:1.2;display:block;"
    class="provider-name-link"
  >
    {name}
  </a>

  <!-- Location eyebrow (Helvetica 12px uppercase) -->
  {locationStr && (
    <p style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:#6e6e6e;margin:0;font-feature-settings:'tnum','zero';">
      {locationStr}
    </p>
  )}

  <!-- Description (clamped to 2 lines, Garamond) -->
  {description && (
    <p style="font-family:'EB Garamond',Garamond,Georgia,serif;font-size:17px;color:#3a4047;line-height:1.5;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
      {description}
    </p>
  )}

  <!-- Category chips (Helvetica labels) -->
  {topCats.length > 0 && (
    <div style="display:flex;flex-wrap:wrap;gap:5px;">
      {topCats.map((cat: string) => {
        const catName = catsMap[cat]
          ? (isMS ? catsMap[cat].name_ms : catsMap[cat].name)
          : cat.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
        return (
          <span style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:10px;font-weight:400;letter-spacing:0.06em;text-transform:uppercase;color:#181818;background:transparent;border:1px solid #d6d6cf;border-radius:0;padding:2px 7px;">
            {catName}
          </span>
        );
      })}
    </div>
  )}

  <!-- Services preview (Helvetica small labels) -->
  {services.length > 0 && (
    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:4px;">
      {services.map((svc: string) => (
        <li style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:11px;letter-spacing:0.04em;color:#6e6e6e;display:flex;align-items:center;gap:8px;">
          <span aria-hidden="true" style="width:14px;height:1px;background:#d6d6cf;flex-shrink:0;display:inline-block;"></span>
          {svc}
        </li>
      ))}
    </ul>
  )}

  <!-- CTA row: view provider arrow-link + optional website link -->
  <div style="margin-top:auto;padding-top:12px;border-top:1px solid #d6d6cf;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
    <a
      href={href}
      class="arrow-link"
      style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:400;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;color:#181818;"
      data-ph="provider_view"
      data-ph-provider={clinic.slug}
      data-ph-locale={locale}
    >
      {viewLabel}
      <span aria-hidden="true" style="color:#fc523b;font-size:14px;line-height:1;margin-left:4px;">&#8599;</span>
    </a>
    {clinic.website && (
      <a
        href={clinic.website}
        target="_blank"
        rel="noopener noreferrer"
        style="font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:#6e6e6e;text-decoration:none;transition:color 100ms;"
        class="website-link"
        data-ph="provider_website"
        data-ph-provider={clinic.slug}
        data-ph-locale={locale}
      >
        {websiteLabel}
        <span aria-hidden="true" style="color:#fc523b;margin-left:3px;">&#8599;</span>
      </a>
    )}
  </div>
</article>

<style>
  .provider-name-link:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .website-link:hover { color: #181818; }
</style>
