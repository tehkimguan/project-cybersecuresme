---
interface Props { locale?: string; }
const { locale = 'en' } = Astro.props;
---

<div class="csc-wrap">
  <div class="csc-field">
    <label class="csc-eyebrow" for="pw-input">Password</label>
    <div class="csc-pw-row">
      <input
        type="password"
        id="pw-input"
        class="csc-input"
        autocomplete="new-password"
        spellcheck="false"
        placeholder="Type a password to test"
        aria-label="Password to test"
        aria-describedby="pw-strength-desc"
      />
      <button type="button" id="pw-toggle" class="csc-toggle-btn" aria-label="Show password">Show</button>
    </div>
  </div>

  <div id="pw-result" class="csc-result-panel" hidden aria-live="polite">
    <div class="csc-result-row">
      <span class="csc-eyebrow">Strength score</span>
      <span class="csc-big-num" id="pw-score">0</span>
    </div>
    <div class="csc-bar-wrap">
      <div class="csc-bar-track">
        <div class="csc-bar-fill" id="pw-bar" style="width:0%"></div>
      </div>
      <div class="csc-bar-label" id="pw-label">--</div>
    </div>
    <div class="csc-result-row csc-mt">
      <span class="csc-eyebrow">Estimated offline crack time</span>
      <span class="csc-mono" id="pw-crack">--</span>
    </div>
    <div class="csc-result-row">
      <span class="csc-eyebrow">Entropy</span>
      <span class="csc-mono" id="pw-entropy">-- bits</span>
    </div>
    <div class="csc-tips" id="pw-tips"></div>
  </div>

  <p class="csc-disclaimer">
    Your password never leaves your browser. Nothing is sent to any server.
    This is a planning aid, not professional security advice. For expert guidance, see
    <a href="/providers/security-awareness" class="csc-link">security awareness providers &rarr;</a>
  </p>
</div>

<style>
  .csc-wrap { display:flex; flex-direction:column; gap:20px; font-family:"EB Garamond",Georgia,serif; }
  .csc-eyebrow { font-family:"Inter","Helvetica Neue",Helvetica,Arial,sans-serif; font-size:12px; letter-spacing:.1em; text-transform:uppercase; color:#181818; font-feature-settings:"tnum"; display:block; margin-bottom:6px; }
  .csc-field { display:flex; flex-direction:column; }
  .csc-pw-row { display:flex; gap:0; }
  .csc-input { background:#fff; border:1px solid #181818; border-radius:0; padding:10px 14px; font-family:"Inter",Arial,sans-serif; font-size:16px; color:#181818; flex:1; min-height:44px; outline:none; }
  .csc-input:focus { outline:2px solid #181818; outline-offset:-2px; }
  .csc-toggle-btn { border:1px solid #181818; border-left:none; background:transparent; color:#181818; font-family:"Inter",Arial,sans-serif; font-size:12px; letter-spacing:.06em; text-transform:uppercase; padding:0 14px; cursor:pointer; white-space:nowrap; }
  .csc-toggle-btn:hover { background:#181818; color:#f2f2f2; }
  .csc-result-panel { background:#f2f2f2; border-top:1px solid #181818; padding:20px; display:flex; flex-direction:column; gap:14px; }
  .csc-result-row { display:flex; align-items:baseline; justify-content:space-between; gap:12px; flex-wrap:wrap; }
  .csc-mt { margin-top:4px; }
  .csc-big-num { font-family:"EB Garamond",Georgia,serif; font-size:36px; line-height:1; color:#181818; }
  .csc-mono { font-family:"Inter",Arial,sans-serif; font-size:14px; font-feature-settings:"tnum"; color:#181818; }
  .csc-bar-wrap { display:flex; flex-direction:column; gap:6px; }
  .csc-bar-track { height:4px; background:#d6d6cf; position:relative; }
  .csc-bar-fill { height:4px; background:#fc523b; transition:width 250ms,background 250ms; }
  .csc-bar-label { font-family:"Inter",Arial,sans-serif; font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:#6e6e6e; }
  .csc-tips { border-top:1px solid #d6d6cf; padding-top:14px; display:flex; flex-direction:column; gap:6px; }
  .csc-tip { font-family:"EB Garamond",Georgia,serif; font-size:16px; color:#181818; padding-left:14px; position:relative; }
  .csc-tip::before { content:"-"; position:absolute; left:0; }
  .csc-disclaimer { font-family:"Inter",Arial,sans-serif; font-size:12px; color:#6e6e6e; line-height:1.5; border-top:1px solid #d6d6cf; padding-top:14px; margin:0; }
  .csc-link { color:#181818; text-decoration:underline; }
  .csc-link:hover { color:#fc523b; }
</style>

<script is:inline define:vars={{ locale }}>
(function () {
  var input = document.getElementById('pw-input');
  var toggle = document.getElementById('pw-toggle');
  var resultPanel = document.getElementById('pw-result');
  var scoreEl = document.getElementById('pw-score');
  var barEl = document.getElementById('pw-bar');
  var labelEl = document.getElementById('pw-label');
  var crackEl = document.getElementById('pw-crack');
  var entropyEl = document.getElementById('pw-entropy');
  var tipsEl = document.getElementById('pw-tips');
  var captured = false;

  toggle.addEventListener('click', function () {
    if (input.type === 'password') {
      input.type = 'text';
      toggle.textContent = 'Hide';
    } else {
      input.type = 'password';
      toggle.textContent = 'Show';
    }
  });

  function charsetSize(pw) {
    var sz = 0;
    if (/[a-z]/.test(pw)) sz += 26;
    if (/[A-Z]/.test(pw)) sz += 26;
    if (/[0-9]/.test(pw)) sz += 10;
    if (/[^a-zA-Z0-9]/.test(pw)) sz += 32;
    return Math.max(sz, 1);
  }

  function entropy(pw) {
    return pw.length * Math.log2(charsetSize(pw));
  }

  // Guesses per second for offline bcrypt (cost 10) is ~10k; for fast hash ~1e11
  // We use a mid-speed offline attack (MD5-level) ~1e10 guesses/s
  function crackTime(bits) {
    var guesses = Math.pow(2, bits) / 2; // avg half keyspace
    var gps = 1e10; // guesses per second (mid offline)
    var secs = guesses / gps;
    if (secs < 1) return 'under a second';
    if (secs < 60) return Math.round(secs) + ' seconds';
    if (secs < 3600) return Math.round(secs/60) + ' minutes';
    if (secs < 86400) return Math.round(secs/3600) + ' hours';
    if (secs < 86400*365) return Math.round(secs/86400) + ' days';
    if (secs < 86400*365*1000) return Math.round(secs/(86400*365)) + ' years';
    if (secs < 86400*365*1e6) return 'thousands of years';
    return 'centuries';
  }

  function scorePassword(pw) {
    var e = entropy(pw);
    var score = Math.min(100, Math.round(e * 1.5));
    return { score: score, entropy: Math.round(e) };
  }

  function tips(pw) {
    var out = [];
    if (pw.length < 12) out.push('Use at least 12 characters - length matters most.');
    if (!/[A-Z]/.test(pw)) out.push('Add uppercase letters to increase the character pool.');
    if (!/[0-9]/.test(pw)) out.push('Include numbers to strengthen entropy.');
    if (!/[^a-zA-Z0-9]/.test(pw)) out.push('Add symbols (!@#$%) for a larger character set.');
    if (pw.length >= 16 && out.length === 0) out.push('Strong. Consider using a password manager to store it safely.');
    return out.slice(0, 3);
  }

  function levelLabel(score) {
    if (score < 30) return 'Weak';
    if (score < 55) return 'Fair';
    if (score < 75) return 'Good';
    return 'Strong';
  }

  function barColor(score) {
    if (score < 30) return '#fc523b';
    if (score < 55) return '#6e6e6e';
    if (score < 75) return '#181818';
    return '#181818';
  }

  function compute() {
    var pw = input.value;
    if (!pw) { resultPanel.setAttribute('hidden', ''); return; }
    resultPanel.removeAttribute('hidden');

    var r = scorePassword(pw);
    scoreEl.textContent = r.score;
    barEl.style.width = r.score + '%';
    barEl.style.background = barColor(r.score);
    labelEl.textContent = levelLabel(r.score);
    crackEl.textContent = crackTime(r.entropy);
    entropyEl.textContent = r.entropy + ' bits';

    tipsEl.innerHTML = tips(pw).map(function(t) {
      return '<p class="csc-tip">' + t + '</p>';
    }).join('');

    if (!captured && pw.length >= 4) {
      captured = true;
      try { if (window.posthog) window.posthog.capture('calculator_used', { tool: 'password-strength-checker' }); } catch(_){}
    }
  }

  input.addEventListener('input', compute);
})();
</script>
